# Copie este arquivo para .env.local e preencha com os valores do seu projeto.
# https://app.supabase.com/project/<SEU_PROJETO>/settings/api

# Supabase (obrigatório)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# URL pública da app (opcional, mas recomendado em produção).
# Usado pelo OAuth/reset password redirect. Sem isso, usamos window.location.origin.
# VITE_PUBLIC_URL=https://app.exemplo.com

# Sentry (opcional). Sem DSN, telemetria fica desativada (no-op).
# Pegue a DSN em https://sentry.io/settings/<org>/projects/<proj>/keys/
# VITE_SENTRY_DSN=https://exemplo@o0.ingest.sentry.io/0
# VITE_SENTRY_ENV=production
